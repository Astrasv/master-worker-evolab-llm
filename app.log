import numpy as np

def tournament_selection(population, fitnesses, tournament_size, seed=None):
    """Select one individual from population using tournament selection.

    Parameters
    ----------
    population : list of np.ndarray
        List of candidate solutions.
    fitnesses : list or np.ndarray
        Corresponding fitness values (lower is better).
    tournament_size : int
        Number of individuals competing in the tournament.
    seed : int, optional
        Seed for NumPy RNG to ensure deterministic selection.

    Returns
    -------
    np.ndarray
        The selected individual.
    """
    pop_size = len(population)
    if not isinstance(tournament_size, int) or tournament_size <= 0 or tournament_size > pop_size:
        raise ValueError("tournament_size must be a positive integer <= population size")
    if seed is not None:
        np.random.seed(seed)
    # Randomly choose tournament participants without replacement
    indices = np.random.choice(pop_size, size=tournament_size, replace=False)
    # Find the index with the best (lowest) fitness among participants
    best_idx = indices[np.argmin([fitnesses[i] for i in indices])]
    return population[best_idx]


