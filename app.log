import numpy as np
import matplotlib.pyplot as plt

# --- Utility functions -----------------------------------------------------

def distance_matrix(coords: np.ndarray) -> np.ndarray:
    """Return a symmetric distance matrix for the given coordinates."""
    diff = coords[:, None, :] - coords[None, :, :]
    return np.sqrt((diff ** 2).sum(-1))


def tour_length(tour: np.ndarray, dist: np.ndarray) -> float:
    """Compute total length of a tour given a distance matrix."""
    return dist[tour, np.roll(tour, -1)].sum()

# --- Genome creation -------------------------------------------------------

def create_individual(n: int = 1000) -> np.ndarray:
    """Generate a random permutation of city indices."""
    return np.random.permutation(n)

# --- Evolutionary operators -----------------------------------------------

def tournament_selection(pop: np.ndarray, fitness: np.ndarray, k: int = 3) -> int:
    """Return index of individual selected by tournament."""
    candidates = np.random.choice(len(pop), k, replace=False)
    return candidates[np.argmin(fitness[candidates])]


def pmx_crossover(parent1: np.ndarray, parent2: np.ndarray) -> np.ndarray:
    """Partially Mapped Crossover (PMX) for permutations."""
    size = len(parent1)
    child = np.full(size, -1, dtype=int)
    # Random crossover points
    cxp1, cxp2 = sorted(np.random.choice(range(size), 2, replace=False))
    # Copy slice from parent1
    child[cxp1:cxp2+1] = parent1[cxp1:cxp2+1]
    # Map remaining positions
    for i in range(cxp1, cxp2+1):
        val = parent2[i]
        if val not in child:
            pos = i
            while True:
                val2 = parent1[pos]
                pos = np.where(parent2 == val2)[0][0]
                if child[pos] == -1:
                    child[pos] = val
                    break
    # Fill remaining positions from parent2
    for i in range(size):
        if child[i] == -1:
            child[i] = parent2[i]
    return child


def swap_mutation(individual: np.ndarray, rate: float = 0.02) -> np.ndarray:
    """Swap mutation with given probability per position."""
    ind = individual.copy()
    for i in range(len(ind)):
        if np.random.rand() < rate:
            j = np.random.randint(len(ind))
            ind[i], ind[j] = ind[j], ind[i]
    return ind

# --- Evolutionary algorithm -----------------------------------------------

def evolutionary_algorithm(coords: np.ndarray, pop_size: int = 50, generations: int = 200) -> tuple[np.ndarray, float]:
    """Run a simple evolutionary algorithm for TSP and return best tour and its length."""
    n = len(coords)
    dist = distance_matrix(coords)
    # Initialize population
    population = np.array([create_individual(n) for _ in range(pop_size)])
    fitness = np.array([tour_length(ind, dist) for ind in population])
    best_idx = np.argmin(fitness)
    best_tour = population[best_idx].copy()
    best_len = fitness[best_idx]

    for _ in range(generations):
        new_pop = []
        for _ in range(pop_size):
            # Selection
            idx1 = tournament_selection(population, fitness)
            idx2 = tournament_selection(population, fitness)
            parent1, parent2 = population[idx1], population[idx2]
            # Crossover
            child = pmx_crossover(parent1, parent2)
            # Mutation
            child = swap_mutation(child)
            new_pop.append(child)
        population = np.array(new_pop)
        fitness = np.array([tour_length(ind, dist) for ind in population])
        # Update best
        cur_best_idx = np.argmin(fitness)
        if fitness[cur_best_idx] < best_len:
            best_len = fitness[cur_best_idx]
            best_tour = population[cur_best_idx].copy()
    return best_tour, best_len

# --- Plotting --------------------------------------------------------------

def plot_tour(coords: np.ndarray, tour: np.ndarray, filename: str = None) -> None:
    """Plot the tour and optionally save to a file."""
    ordered = coords[tour]
    plt.figure(figsize=(8, 8))
    plt.scatter(ordered[:, 0], ordered[:, 1], c='blue', s=10)
    plt.plot(ordered[:, 0], ordered[:, 1], c='red', linewidth=1)
    # Close the loop
    plt.plot([ordered[-1, 0], ordered[0, 0]], [ordered[-1, 1], ordered[0, 1]], c='red', linewidth=1)
    plt.title('Best TSP Tour')
    plt.axis('equal')
    if filename:
        plt.savefig(filename, dpi=300)
    plt.show()

# --- Main -----------------------------------------------------------------

def main() -> None:
    np.random.seed(42)
    n_cities = 1000
    coords = np.random.rand(n_cities, 2) * 1000  # random coordinates in 1000x1000 grid
    best_tour, best_len = evolutionary_algorithm(coords)
    print(f"Best tour length: {best_len:.2f}")
    plot_tour(coords, best_tour, filename='best_tour.png')

if __name__ == "__main__":
    main()


