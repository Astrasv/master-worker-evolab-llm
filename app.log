def create_individual(seed=None):
    import numpy as np
    if seed is not None:
        if not isinstance(seed, int):
            raise ValueError("seed must be an integer")
        rng = np.random.default_rng(seed)
        genome = rng.permutation(1000)
    else:
        genome = np.random.permutation(1000)
    return genome

