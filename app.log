import numpy as np

def create_individual():
    genome = np.random.permutation(1000)
    return genome

def initialize_population(pop_size: int):
    return [create_individual() for _ in range(pop_size)]

def compute_fitness(individual: np.ndarray) -> float:
    return float(np.sum(individual))

def tournament_selection(population: list, fitnesses: list, tournament_size: int) -> np.ndarray:
    indices = np.random.choice(len(population), size=tournament_size, replace=False)
    best_idx = indices[np.argmin([fitnesses[i] for i in indices])]
    return population[best_idx]

def order_crossover(parent1: np.ndarray, parent2: np.ndarray) -> np.ndarray:
    size = len(parent1)
    child = np.empty(size, dtype=int)
    child.fill(-1)
    start, end = sorted(np.random.choice(range(size), size=2, replace=False))
    child[start:end+1] = parent1[start:end+1]
    fill_pos = (end + 1) % size
    for gene in parent2:
        if gene not in child:
            child[fill_pos] = gene
            fill_pos = (fill_pos + 1) % size
    return child

def swap_mutation(genome: np.ndarray, mutation_rate: float) -> np.ndarray:
    if np.random.rand() < mutation_rate:
        i, j = np.random.choice(len(genome), size=2, replace=False)
        genome[i], genome[j] = genome[j], genome[i]
    return genome

def run_ea(pop_size: int, generations: int, mutation_rate: float, tournament_size: int, seed: int | None = None):
    if pop_size <= 0 or generations <= 0 or tournament_size <= 0:
        raise ValueError("pop_size, generations, and tournament_size must be positive")
    if not (0.0 <= mutation_rate <= 1.0):
        raise ValueError("mutation_rate must be in [0, 1]")
    if seed is not None:
        np.random.seed(seed)
    population = initialize_population(pop_size)
    best_individual = None
    best_fitness = float('inf')
    for gen in range(generations):
        fitnesses = [compute_fitness(ind) for ind in population]
        gen_best_idx = np.argmin(fitnesses)
        if fitnesses[gen_best_idx] < best_fitness:
            best_fitness = fitnesses[gen_best_idx]
            best_individual = population[gen_best_idx].copy()
        new_population = [best_individual.copy()]
        while len(new_population) < pop_size:
            parent1 = tournament_selection(population, fitnesses, tournament_size)
            parent2 = tournament_selection(population, fitnesses, tournament_size)
            child = order_crossover(parent1, parent2)
            child = swap_mutation(child, mutation_rate)
            new_population.append(child)
        population = new_population
        if (gen + 1) % 10 == 0:
            print(f"Generation {gen+1}: Best fitness = {best_fitness}")
    return best_individual, best_fitness

