import numpy as np

def compute_fitness(individual: np.ndarray, coordinates: np.ndarray) -> float:
    """
    Compute total Euclidean distance of the tour defined by `individual`.
    Parameters
    ----------
    individual : np.ndarray
        1D array of city indices (length 1000).
    coordinates : np.ndarray
        2D array of shape (1000, 2) with city positions.
    Returns
    -------
    float
        Total tour distance (lower is better).
    Raises
    ------
    ValueError
        If input shapes are invalid.
    """
    if not isinstance(individual, np.ndarray) or not isinstance(coordinates, np.ndarray):
        raise ValueError("Both individual and coordinates must be numpy arrays.")
    if individual.ndim != 1:
        raise ValueError("Individual must be a 1D array.")
    if coordinates.ndim != 2 or coordinates.shape[1] != 2:
        raise ValueError("Coordinates must be a 2D array with shape (N, 2).")
    if individual.size != coordinates.shape[0]:
        raise ValueError("Individual length must match number of coordinates.")
    tour_coords = coordinates[individual]
    diff = np.diff(tour_coords, axis=0)
    last_to_first = tour_coords[0] - tour_coords[-1]
    diff = np.vstack([diff, last_to_first])
    distances = np.linalg.norm(diff, axis=1)
    return float(np.sum(distances))

