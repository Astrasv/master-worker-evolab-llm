import numpy as np
class Individual:
    def __init__(self, genome=None):
        if genome is None:
            self.genome = self.create_genome()
        else:
            self.genome = genome
        self.fitness = None

    @staticmethod
    def create_genome():
        num_cities = 1000
        return np.random.permutation(num_cities)

    def mutate(self, mutation_rate=0.01):
        if np.random.rand() < mutation_rate:
            idx1, idx2 = np.random.choice(len(self.genome), 2, replace=False)
            self.genome[idx1], self.genome[idx2] = self.genome[idx2], self.genome[idx1]

    def crossover(self, other, crossover_rate=0.5):
        if np.random.rand() < crossover_rate:
            crossover_point = np.random.randint(1, len(self.genome))
            child1 = np.concatenate((self.genome[:crossover_point], other.genome[crossover_point:]))
            child2 = np.concatenate((other.genome[:crossover_point], self.genome[crossover_point:]))
            return Individual(child1), Individual(child2)
        else:
            return self, other

