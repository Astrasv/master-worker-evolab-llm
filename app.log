import numpy as np

class TSPTour:
    def __init__(self, tour: np.ndarray):
        if not isinstance(tour, np.ndarray):
            raise TypeError("tour must be a numpy array")
        if tour.shape != (1000,):
            raise ValueError("tour must have shape (1000,)")
        if not np.array_equal(np.sort(tour), np.arange(1000)):
            raise ValueError("tour must contain each city index 0-999 exactly once")
        self._tour = tour.copy()

    def get_tour(self) -> np.ndarray:
        return self._tour.copy()

    def is_valid(self) -> bool:
        return np.array_equal(np.sort(self._tour), np.arange(1000))

    def __len__(self):
        return len(self._tour)

    def __repr__(self):
        return f"TSPTour(tour={self._tour})"


