import numpy as np
def calculate_distance(city_coords, individual):
    total_distance = 0
    for i in range(len(individual) - 1):
        city1 = individual[i]
        city2 = individual[i + 1]
        distance = np.linalg.norm(city_coords[city1] - city_coords[city2])
        total_distance += distance
    # add distance from last city back to first city to complete the route
    distance = np.linalg.norm(city_coords[individual[-1]] - city_coords[individual[0]])
    total_distance += distance
    return total_distance
def fitness_function(city_coords, individual):
    distance = calculate_distance(city_coords, individual)
    return 1 / distance

