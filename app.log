import numpy as np

def compute_fitness(individual, coordinates):
    individual = np.asarray(individual, dtype=int)
    coordinates = np.asarray(coordinates, dtype=float)
    n = coordinates.shape[0]
    if coordinates.shape != (n, 2) or n != 1000:
        raise ValueError("coordinates must be shape (1000,2)")
    if individual.shape != (n,):
        raise ValueError("individual must be length 1000")
    if not np.array_equal(np.sort(individual), np.arange(n)):
        raise ValueError("individual must be a permutation of 0-999")
    idx = np.concatenate([individual, [individual[0]]])
    pts = coordinates[idx]
    diffs = np.diff(pts, axis=0)
    dists = np.sqrt((diffs**2).sum(axis=1))
    return float(dists.sum())

