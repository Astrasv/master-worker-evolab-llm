import numpy as np

def create_individual():
    num_cities = 1000
    genome = np.random.permutation(num_cities)
    return genome

def fitness(individual):
    # Example fitness function: total distance of the route
    num_cities = len(individual)
    distance = 0
    for i in range(num_cities - 1):
        distance += np.linalg.norm(np.array([individual[i], individual[i]]) - np.array([individual[i+1], individual[i+1]]))
    distance += np.linalg.norm(np.array([individual[-1], individual[-1]]) - np.array([individual[0], individual[0]]))
    return -distance  # Minimize distance

def selection(population, num_parents, fitness_func):
    fitness_values = [fitness_func(individual) for individual in population]
    sorted_indices = np.argsort(fitness_values)
    selected_indices = sorted_indices[:num_parents]
    selected_parents = [population[i] for i in selected_indices]
    return selected_parents

def crossover(parent1, parent2):
    num_cities = len(parent1)
    crossover_point = np.random.randint(1, num_cities - 1)
    child = np.zeros(num_cities, dtype=int)
    child[:crossover_point] = parent1[:crossover_point]
    for city in parent2:
        if city not in child:
            for i in range(crossover_point, num_cities):
                if child[i] == 0:
                    child[i] = city
                    break
    return child

def mutation(individual, mutation_rate):
    num_cities = len(individual)
    if np.random.rand() < mutation_rate:
        i, j = np.random.choice(num_cities, size=2, replace=False)
        individual[i], individual[j] = individual[j], individual[i]
    return individual

def evolutionary_loop(population_size, num_generations, num_parents, mutation_rate):
    population = [create_individual() for _ in range(population_size)]
    for generation in range(num_generations):
        selected_parents = selection(population, num_parents, fitness)
        offspring = []
        while len(offspring) < population_size - num_parents:
            parent1, parent2 = np.random.choice(selected_parents, size=2, replace=False)
            child = crossover(parent1, parent2)
            child = mutation(child, mutation_rate)
            offspring.append(child)
        population = selected_parents + offspring
    return population


