import numpy as np

def ordered_crossover(parent1, parent2):
    num_cities = len(parent1)
    start_idx = np.random.randint(0, num_cities)
    end_idx = np.random.randint(0, num_cities)
    if start_idx > end_idx:
        start_idx, end_idx = end_idx, start_idx
    child = np.full(num_cities, -1)
    child[start_idx:end_idx] = parent1[start_idx:end_idx]
    idx = 0
    for city in parent2:
        if city not in child:
            while child[idx] != -1:
                idx += 1
            child[idx] = city
    return child

def partially_mapped_crossover(parent1, parent2):
    num_cities = len(parent1)
    start_idx = np.random.randint(0, num_cities)
    end_idx = np.random.randint(0, num_cities)
    if start_idx > end_idx:
        start_idx, end_idx = end_idx, start_idx
    child = np.full(num_cities, -1)
    child[start_idx:end_idx] = parent1[start_idx:end_idx]
    mapping = {}
    for i in range(start_idx, end_idx):
        mapping[parent1[i]] = parent2[i]
    for i in range(num_cities):
        if child[i] == -1:
            city = parent2[i]
            while city in mapping:
                city = mapping[city]
            child[i] = city
    return child

def swap_mutation(genome):
    num_cities = len(genome)
    idx1, idx2 = np.random.choice(num_cities, 2, replace=False)
    genome[idx1], genome[idx2] = genome[idx2], genome[idx1]
    return genome

def inversion_mutation(genome):
    num_cities = len(genome)
    start_idx = np.random.randint(0, num_cities)
    end_idx = np.random.randint(0, num_cities)
    if start_idx > end_idx:
        start_idx, end_idx = end_idx, start_idx
    genome[start_idx:end_idx] = genome[start_idx:end_idx][::-1]
    return genome

