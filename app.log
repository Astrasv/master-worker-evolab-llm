import numpy as np

def initialize_population(pop_size, seed=None):
    """Return a list of `pop_size` distinct individuals.

    Parameters
    ----------
    pop_size : int
        Number of individuals to generate.
    seed : int, optional
        Random seed for reproducibility.

    Returns
    -------
    list of np.ndarray
        List of distinct individuals.
    """
    if seed is not None:
        np.random.seed(seed)
    population = []
    seen = set()
    while len(population) < pop_size:
        indiv = create_individual()
        key = tuple(indiv)
        if key not in seen:
            seen.add(key)
            population.append(indiv)
    return population

