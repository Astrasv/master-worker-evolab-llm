import numpy as np
class Individual:
    def __init__(self, genome=None):
        if genome is None:
            self.genome = self.create_genome()
        else:
            self.genome = genome
        self.fitness = None

    @staticmethod
    def create_genome():
        num_cities = 1000
        return np.random.permutation(num_cities)

    def mutate(self, mutation_rate=0.01):
        if np.random.rand() < mutation_rate:
            idx1, idx2 = np.random.choice(self.genome.shape[0], 2, replace=False)
            self.genome[[idx1, idx2]] = self.genome[[idx2, idx1]]

    def crossover(self, other):
        child_genome = np.zeros_like(self.genome)
        start_idx = np.random.randint(0, self.genome.shape[0])
        end_idx = np.random.randint(start_idx + 1, self.genome.shape[0] + 1)
        child_genome[start_idx:end_idx] = self.genome[start_idx:end_idx]
        other_idx = 0
        for i in range(self.genome.shape[0]):
            if child_genome[i] == 0:
                while other.genome[other_idx] in child_genome:
                    other_idx += 1
                child_genome[i] = other.genome[other_idx]
                other_idx += 1
        return Individual(genome=child_genome)


