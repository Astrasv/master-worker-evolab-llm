import matplotlib.pyplot as plt
import numpy as np
def visualize_solution(genome, city_coordinates):
    if not isinstance(genome, np.ndarray) or not isinstance(city_coordinates, np.ndarray):
        raise TypeError('Invalid input type')
    if len(genome) != len(city_coordinates):
        raise ValueError('Genome and city_coordinates must have the same length')
    if len(genome) == 0 or len(city_coordinates) == 0:
        raise ValueError('Genome and city_coordinates cannot be empty')
    plt.figure(figsize=(10, 10))
    plt.scatter(city_coordinates[:, 0], city_coordinates[:, 1])
    for i in range(len(genome) - 1):
        city1 = city_coordinates[genome[i]]
        city2 = city_coordinates[genome[i + 1]]
        plt.plot([city1[0], city2[0]], [city1[1], city2[1]], 'k-')
    city1 = city_coordinates[genome[-1]]
    city2 = city_coordinates[genome[0]]
    plt.plot([city1[0], city2[0]], [city1[1], city2[1]], 'k-')
    plt.show()

