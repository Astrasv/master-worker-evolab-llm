import matplotlib.pyplot as plt
import numpy as np
def visualize_solution(genome, city_coordinates):
    num_cities = len(genome)
    plt.figure(figsize=(10, 10))
    for i in range(num_cities):
        city_index = genome[i]
        x, y = city_coordinates[city_index]
        plt.scatter(x, y)
        if i > 0:
            prev_city_index = genome[i-1]
            prev_x, prev_y = city_coordinates[prev_city_index]
            plt.plot([prev_x, x], [prev_y, y], 'k-')
    plt.scatter(city_coordinates[genome[0], 0], city_coordinates[genome[0], 1], c='r')
    plt.scatter(city_coordinates[genome[-1], 0], city_coordinates[genome[-1], 1], c='g')
    plt.show()

