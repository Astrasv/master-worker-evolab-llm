import numpy as np

def order_crossover(parent1: np.ndarray, parent2: np.ndarray) -> np.ndarray:
    """Perform Order Crossover (OX) on two parent permutations.

    Parameters
    ----------
    parent1, parent2 : np.ndarray
        Parent permutations of length 1000 containing integers 0-999.

    Returns
    -------
    np.ndarray
        Child permutation produced by OX.

    Raises
    ------
    ValueError
        If either parent is not a valid permutation of 0-999.
    """
    # Ensure inputs are numpy arrays
    p1 = np.asarray(parent1, dtype=int)
    p2 = np.asarray(parent2, dtype=int)

    # Validate length
    if p1.size != 1000 or p2.size != 1000:
        raise ValueError("Parents must be permutations of length 1000.")

    # Validate that each parent is a permutation of 0-999
    if not np.array_equal(np.sort(p1), np.arange(1000)) or not np.array_equal(np.sort(p2), np.arange(1000)):
        raise ValueError("Parents must be valid permutations of 0-999.")

    # Randomly select two cut points
    cut1, cut2 = np.sort(np.random.choice(1000, 2, replace=False))

    # Initialize child with sentinel value
    child = np.full(1000, -1, dtype=int)

    # Copy segment from parent1
    child[cut1:cut2+1] = p1[cut1:cut2+1]

    # Fill remaining positions with order from parent2, skipping duplicates
    child_pos = 0
    for city in p2:
        if city not in child:
            # Find next empty slot in child
            while child[child_pos] != -1:
                child_pos += 1
            child[child_pos] = city

    # Final validation: child must be a permutation of 0-999
    if not np.array_equal(np.sort(child), np.arange(1000)):
        raise RuntimeError("Child is not a valid permutation after crossover.")

    return child


